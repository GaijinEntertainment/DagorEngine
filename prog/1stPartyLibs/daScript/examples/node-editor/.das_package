options gen2
require daslib/daspkg

[export]
def package() {
    package_name("node-editor-example")
    package_description("Node editor example using dasImguiNodeEditor")
}

[export]
def dependencies(version : string) {
    require_package("dasImguiNodeEditor")
}

[export]
def release() {
    release_main("imgui_node_editor_basic.das")
}
