options gen2
require daslib/daspkg

[export]
def package() {
    package_name("graphics-example")
    package_description("Graphics example using dasImgui")
}

[export]
def dependencies(version : string) {
    require_package("dasImgui")
}

[export]
def release() {
    release_main("furier_opengl_imgui_example.das")
}
