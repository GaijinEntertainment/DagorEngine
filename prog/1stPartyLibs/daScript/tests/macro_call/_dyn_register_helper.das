// Helper: declares a function-annotation [dyn_register_42] whose apply()
// dynamically registers a per-decl AstCallMacro instance via
// add_call_macro(make_call_macro(...)). The registered call_macro folds
// any call to the decorated name into the constant 42 — the function body
// never runs. The sibling test asserts the dispatch happens.
//
// This is the same pattern dasImgui's [widget] uses
// (D:\DASPKG\dasImgui\widgets\imgui_boost.das:75-79). Regression target:
// if daslang ever changes how dynamically-registered call_macros are
// resolved at the call site, this fixture fails first.
//
// Cross-file structure is required: an annotation generated by a
// meta-macro class is NOT visible in the same source file that declared
// the class. The annotated def lives in _dyn_register_decl.das, not here.
options gen2
options indenting = 4

module _dyn_register_helper public

require daslib/ast public
require daslib/ast_boost
require daslib/templates_boost

class FortyTwoCallMacro : AstCallMacro {
    macro_name : string

    def override visit(prog : ProgramPtr; mod : Module?;
                       var call : ExprCallMacro?) : ExpressionPtr {
        return <- new ExprConstInt(at = call.at, value = 42)
    }
}

[function_macro(name = "dyn_register_42")]
class DynRegisterFortyTwo : AstFunctionAnnotation {
    def override apply(var func : FunctionPtr; var group : ModuleGroup;
                       args : AnnotationArgumentList; var errors : das_string) : bool {
        let name = string(func.name)
        var inst = new FortyTwoCallMacro(macro_name = name)
        compiling_module() |> add_call_macro(make_call_macro(name, inst))
        return true
    }
}
