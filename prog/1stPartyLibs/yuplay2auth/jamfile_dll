Root             ?= ../../.. ;
Location          = prog/1stPartyLibs/yuplay2auth ;

Yuplay2UseGnome  ?= no ;

UseZlibVer       ?= ng ;
UseMemoryAllocator = RTL ;


include $(Root)/prog/_jBuild/defaults.jam ;


TargetType        = dll ;

#One should run jam with -sOutDir=PathToFolderWhereYuplay2AuthDllNeeded
if $(Platform) = windows {
  if $(PlatformArch) = x86 {
    Target       ?= yuplay2auth.dll ;
  } else {
    Target       ?= yuplay2auth64.dll ;
  }
}
else {
  Target         ?= yuplay2auth.so ;

  Yuplay2UseGnome = yes ;
}


AddIncludes =
  $(Root)/$(Location)
  $(Root)/$(Location)/include
  $(Root)/$(Location)/session
  $(Root)/prog/1stPartyLibs/yuplay2
  $(Root)/prog/1stPartyLibs/yuplay2/include
  $(Root)/prog/3rdPartyLibs/Tencent
;

if $(UseSystemLibcurl) != yes {
  AddIncludes += $(Root)/prog/3rdPartyLibs/libcurl/include ;
}

if $(Yuplay2UseGnome) = yes {
  AddIncludes +=
    /usr/include/gtk-3.0
    /usr/include/glib-2.0
    /usr/lib64/glib-2.0/include
    /usr/include/pango-1.0
    /usr/include/cairo
    /usr/include/gdk-pixbuf-2.0
    /usr/include/atk-1.0
  ;
}


Sources =
  yu_answer.cpp
  yu_friends.cpp
  yu_itemInfo.cpp
  yu_syncCb.cpp
  yu_userInfo.cpp

  yuplay2_core.cpp
  yuplay2_test.cpp

  session/yu_session.cpp
  session/yu_sessionAction.cpp
  session/yu_sessionFallback.cpp
  session/yu_sessionHttp.cpp
  session/yu_sessionLoginBase.cpp
  session/yu_sessionProc.cpp
  session/yuplay2_session.cpp
;


UseProgLibs =
  3rdPartyLibs/eastl
  3rdPartyLibs/arc/zlib-$(UseZlibVer)
  1stPartyLibs/yuplay2

  engine/kernel
  engine/startup
  engine/baseUtil
  engine/osApiWrappers
  engine/memory
  engine/perfMon/daProfilerStub
;

if $(UseSystemLibcurl) != yes {
  UseProgLibs += 3rdPartyLibs/libcurl ;
}


if $(UseSystemOpenSSL) != yes {
  AddIncludes += $(Root)/prog/3rdPartyLibs/openssl-$(OpenSSLVer)/include ;
  UseProgLibs += 3rdPartyLibs/openssl-$(OpenSSLVer) ;
}


CPPopt =
  -DCURL_STATICLIB
  -DOPENSSL_SUPPRESS_DEPRECATED
  -DYU2_LIBRARY_DLL=1
  -DYU2_LIBRARY_DLL_EXPORT=1
;

if $(Yuplay2UseGnome) = yes {
  CPPopt += -DYUPLAY2_USE_GNOME ;
}

if $(Platform) = linux {
  CPPopt += -Wno-unused-parameter ;
}


if $(Platform) in windows {
  AddLibs =
    user32.lib
    shlwapi.lib
    shell32.lib
    version.lib
    oleaut32.lib
    dbghelp.lib
    ole32.lib
  ;
} else if $(Platform) = macOS {
  AddLibs =
    -liconv
  ;
} else if $(Platform) = linux {
  AddLibs =
    -lpthread
  ;

  if $(Yuplay2UseGnome) = yes {
    AddLibs +=
      -lgio-2.0
    ;
  }
}


include $(Root)/prog/_jBuild/build.jam ;
