Root    ?= ../../../../../.. ;
Location = prog/1stPartyLibs/quirrel/quirrel/squirrel/compiler ;

TargetType  = lib ;

local TargetLib = 1stPartyLibs/v/quirrel-compiler ;
if $(SqVarTrace) = yes { TargetLib = $(TargetLib)~vt ; }
Target = $(TargetLib).lib ;

AddIncludes =
  $(Root)/prog/1stPartyLibs/eastl/include
  $(Root)/prog/1stPartyLibs/quirrel/quirrel/squirrel
  $(Root)/prog/1stPartyLibs/quirrel/quirrel/squirrel/compiler
  $(Root)/prog/1stPartyLibs/quirrel/quirrel/helpers
  $(Root)/prog/1stPartyLibs/quirrel/quirrel/internal
;

include $(Root)/prog/_jBuild/add_quirrel.jam ;

Sources =
  ast.cpp
  compilationcontext.cpp
  parser.cpp
  codegen.cpp
  typeinference.cpp
  constgen.cpp
  sqio.cpp
  compiler.cpp
  sqfuncstate.cpp
  sqdump.cpp
  optimizer.cpp
  lexer.cpp
  sqtypeparser.cpp
  optimizations/closureHoisting.cpp
  static_analyzer/analyzer.cpp
  static_analyzer/checker_visitor.cpp
  static_analyzer/name_shadowing_checker.cpp
  static_analyzer/function_ret_type_eval.cpp
  static_analyzer/config.cpp
  static_analyzer/var_scope.cpp
  static_analyzer/value_ref.cpp
  static_analyzer/naming.cpp
  static_analyzer/global_state.cpp
  static_analyzer/external_value.cpp
;

UseProgLibs +=
  3rdPartyLibs/eastl
;

if $(SqVarTrace) = yes {
  CPPopt += -DSQ_VAR_TRACE_ENABLED ;
}

# Enable C++ exceptions for compiler
if $(Platform) in windows xboxOne scarlett {
  CPPopt += /EHsc ;
} else {
  CPPopt += -fexceptions ;
}

Copt   = $(CPPopt) ;

include $(Root)/prog/_jBuild/build.jam ;
