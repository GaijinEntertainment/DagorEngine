Root    ?= ../../.. ;
Location = prog/gameLibs/websocket ;
StrictCompile = yes ;
TargetType  = lib ;
Target      = gameLibs/websocket.lib ;

include $(Root)/prog/_jBuild/defaults.jam ;

AddIncludes +=
  $(Root)/prog/gameLibs/publicInclude
  $(Root)/prog/3rdPartyLibs/libb64/include
;

UseProgLibs += 3rdPartyLibs/eastl
               3rdPartyLibs/libb64
;

Sources = websocket.cpp ;

if $(Platform) in nswitch {
  # nintendo switch uses internal libcurl library
} else {
  if $(UseSystemLibcurl) != yes {
    AddIncludes += $(Root)/prog/3rdPartyLibs/libcurl/include ;
    UseProgLibs += 3rdPartyLibs/libcurl ;
    CPPopt += -DCURL_STATICLIB -DOPENSSL_SUPPRESS_DEPRECATED ;
  }
}

if $(Platform) in windows {
  CPPopt += /FC ;        # enable full path in __FILE__ macro (useful when navigating output with for IDE)
}


if $(UseSystemOpenSSL) != yes {
  AddIncludes += $(Root)/prog/3rdPartyLibs/openssl-$(OpenSSLVer)/include ;
  UseProgLibs += 3rdPartyLibs/openssl-$(OpenSSLVer) ;
}

include $(Root)/prog/_jBuild/build.jam ;
