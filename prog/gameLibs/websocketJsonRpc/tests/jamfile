Root           ?= ../../../.. ;
Location        = prog/gameLibs/websocketJsonRpc/tests ;
ConsoleExe      = yes ;
TargetType      = exe ;
Target          = websocketJsonRpc-tests ;
OutDir          = $(Root)/_output/dagorUnitTests ;

include $(Root)/prog/_jBuild/defaults.jam ;


local AllSrcFolder_CPP =
  .
  wsJsonRpcConnection
  wsJsonRpcPersistentConnection
;


AutoscanBuildLists $(AllSrcFolder_CPP) : *.cpp       : Sources ;


AddIncludes +=
  $(Root)/prog/3rdPartyLibs/catch2/src
  $(Root)/prog/3rdPartyLibs/rapidjson/include
  $(Root)/prog/gameLibs/publicInclude
  $(Root)/prog/gameLibs/websocketJsonRpc/tests
;


CPPopt += -DUSE_EASTL ;  # enable EASTL assertion interception in Catch2 (main.cpp)

if $(Platform) in windows {
  CPPopt += /FC ;        # enable full path in __FILE__ macro (useful when navigating output with for IDE)
}


UseProgLibs +=
  engine/memory
  engine/kernel
  engine/osApiWrappers
  engine/baseUtil
  engine/perfMon/daProfilerStub

  3rdPartyLibs/catch2
  3rdPartyLibs/eastl

  gameLibs/websocketJsonRpc
  gameLibs/websocketJsonRpc/tests/testHelpers
;


include $(Root)/prog/_jBuild/build.jam ;
