Root    ?= ../../../.. ;
Location = prog/gameLibs/quirrel/bindQuirrelEx ;
StrictCompile = yes ;
UseQuirrel = yes ;

TargetType  = lib ;
Target      = gameLibs/quirrel/bindQuirrelEx.lib ;

include $(Root)/prog/_jBuild/defaults.jam ;

AddIncludes =
  $(Root)/prog/engine/sharedInclude
  $(Root)/prog/gameLibs/publicInclude
  $(Root)/prog/gameLibs/publicInclude/quirrel
  $(Root)/prog/3rdPartyLibs/pcre/pcre
  $(Root)/prog/3rdPartyLibs/utf8
  $(Root)/prog/3rdPartyLibs/arc/libzip/lib
;

if $(Platform) in ps4 ps5 {
  AddIncludes += $(Root)/prog/3rdPartyLibs/posix/include/ps4 ;
}

Sources =
  sqRegExp.cpp
  sqUtf8.cpp
  autoBind.cpp
  autoCleanup.cpp
  bindSqrat.cpp
  sqModulesDagor.cpp
  fileDropHandler.cpp
  screenshotMetaInfoLoader.cpp
  sqratDagorMath.cpp
  sqratDagorDebug.cpp
  logerrSqInterceptor.cpp
  sqratDataBlock.cpp
  sqratIso8601Time.cpp
  random.cpp
  hash.cpp
  zipArchive.cpp
  platformMisc.cpp
  cpuinfo.cpp
  dagorSystem.cpp
  dagorSystemFileHandlers.cpp
  dagorTime.cpp
  dagorWorkCycle.cpp
  dagorFS.cpp
  dagorFolders.cpp
  dagorShell.cpp
  dagorClipboard.cpp
  localization.cpp
  chinese-hypenation.cpp
  japanese-hypenation.cpp
  helpers.cpp
;

if $(Platform) = macOS {
  Sources +=
    dagorSystemMac.mm
  ;
}

if $(Platform) = linux {
  if $(LinuxUseGUI) = yes {
    Sources +=
      dagorSystemLinux.cpp
    ;
  }
  else
  {
    Sources +=
      dagorSystemLinuxStub.cpp
    ;
  }
}

if $(Platform) in windows {
  CPPopt += /wd4548 ; # devtools\win.sdk.100\Include\10.0.10586.0\ucrt\malloc.h(160): warning C4548: expression before comma has no effect; expected expression with side-effect
}

if $(PlatformSpec) in gcc {
  CPPopt += -Wno-uninitialized ; # disable false-positive heuristics from gcc 11
}

CPPopt += -DZIP_STATIC ;

UseProgLibs =
  engine/workCycle
  3rdPartyLibs/pcre
  3rdPartyLibs/uuidv7
  3rdPartyLibs/arc/libzip
  gameLibs/iso8601Time
;

if $(Platform) in android linux macOS ps4 ps5 scarlett xboxOne windows && $(PlatformArch) != e2k {
  UseProgLibs += 3rdPartyLibs/cpu_features ;
}


include $(Root)/prog/_jBuild/build.jam ;
