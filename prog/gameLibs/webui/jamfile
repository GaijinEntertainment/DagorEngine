Root    ?= ../../.. ;
Location = prog/gameLibs/webui ;
StrictCompile = yes ;

include $(Root)/prog/_jBuild/defaults.jam ;

TargetType  = lib ;
Target      = gameLibs/webui.lib ;

AddIncludes =  
  $(Root)/prog/gameLibs/publicInclude/quirrel
  $(Root)/prog/gameLibs/publicInclude
  $(Root)/prog/dagorInclude
  $(Root)/prog/engine/sharedInclude # kind of hack for access to shaders implementation
;

Sources =
  httpserver.cpp
  bson.cpp
;

SourceStr =
  webuiIndexTemplate.html
;

for s in $(SourceStr) { StringifySourceFile $(s) : $(s).inl : httpserver.cpp ; }


local Plugins = gameLibs/webui/plugins ;
UseProgLibs =
  $(Plugins)/colorpicker
  $(Plugins)/dagor
  $(Plugins)/dargMcp
  $(Plugins)/editvar
  $(Plugins)/grapheditor
  $(Plugins)/profiler
  $(Plugins)/screenshot
  $(Plugins)/shadervars
  $(Plugins)/quirrel
;

if $(Platform) = tvOS {
  UseProgLibs +=
    $(Plugins)/tvOS
  ;
}

Plugins = ;

include $(Root)/prog/_jBuild/build.jam ;
