tactical_laser_beam_render_settings {
  _tags:t="render"
  _singleton:b=true
  _track:b=true

  tac_laser_render__min_intensity_angle:r = 90.0
  tac_laser_render__min_intensity_mul:r = 1.0
  tac_laser_render__max_intensity_angle:r = 0.0
  tac_laser_render__max_intensity_mul:r = 1.0
  tac_laser_render__fog_intensity_mul:r = 0.0
  tac_laser_render__fade_dist:r = 25.0
}

