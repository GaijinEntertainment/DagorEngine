Root    ?= ../../../.. ;
Location = prog/3rdPartyLibs/recastnavigation/DetourTileCache ;

include $(Root)/prog/_jBuild/defaults.jam ;

TargetType  = lib ;
Target      = 3rdPartyLibs/DetourTileCache.lib ;

Sources =
  Source/DetourTileCache.cpp
  Source/DetourTileCacheBuilder.cpp
;

AddIncludes =
  $(Root)/prog/3rdPartyLibs/recastnavigation/DetourTileCache/Include
  $(Root)/prog/3rdPartyLibs/recastnavigation/Detour/Include
;

CPPopt += -D_RELEASE ;

if $(Platform) = linux || $(PlatformSpec) = clang {
  if $(Platform) in windows xboxOne scarlett {
    CPPopt += -fp:fast ;
    if $(PlatformArch) != arm64 { CPPopt += /clang:-fno-unsafe-math-optimizations ; }
  } else {
    CPPopt += -ffast-math ;
    if ! $(Platform) in iOS nswitch && ! $(PlatformArch) in e2k { CPPopt += -fno-unsafe-math-optimizations ; }
  }
}

include $(Root)/prog/_jBuild/build.jam ;
