Root    ?= ../../../.. ;
Location = prog/3rdPartyLibs/recastnavigation/Recast ;

include $(Root)/prog/_jBuild/defaults.jam ;

TargetType  = lib ;
Target      = 3rdPartyLibs/recastnavigation/recast.lib ;

Sources =
  Source/Recast.cpp
  Source/RecastAlloc.cpp
  Source/RecastArea.cpp
  Source/RecastAssert.cpp
  Source/RecastContour.cpp
  Source/RecastFilter.cpp
  Source/RecastLayers.cpp
  Source/RecastMesh.cpp
  Source/RecastMeshDetail.cpp
  Source/RecastRasterization.cpp
  Source/RecastRegion.cpp
;

AddIncludes = $(Root)/prog/3rdPartyLibs/recastnavigation/Recast/Include ;

CPPopt += -D_RELEASE ;

if $(Platform) = linux || $(PlatformSpec) = clang {
  if $(Platform) in windows xboxOne scarlett {
    CPPopt += -fp:fast ;
    if $(PlatformArch) != arm64 { CPPopt += /clang:-fno-unsafe-math-optimizations ; }
  } else {
    CPPopt += -ffast-math ;
    if ! $(Platform) in iOS nswitch && ! $(PlatformArch) in e2k { CPPopt += -fno-unsafe-math-optimizations ; }
  }
}

include $(Root)/prog/_jBuild/build.jam ;
