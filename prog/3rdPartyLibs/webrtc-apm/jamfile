Root           ?= ../../.. ;
Location        = prog/3rdPartyLibs/webrtc-apm ;

TargetType      = lib ;
Target          = 3rdPartyLibs/webrtc-apm.lib ;


include $(Root)/prog/_jBuild/defaults.jam ;

AddIncludes =
  $(Root)/$(Location)/webrtc
  $(Root)/prog/3rdPartyLibs/abseil
;

UseProgLibs = 3rdPartyLibs/abseil ;

CPPopt += -DWEBRTC_APM_DEBUG_DUMP=0
          -DWEBRTC_LIBRARY_IMPL=1
;

if $(Platform) in linux ps4 ps5 macOS iOS tvOS nswitch {
  CPPopt += -DWEBRTC_POSIX=1 ;
}

if $(Platform) in linux {
  CPPopt += -DWEBRTC_LINUX=1 ;
}
else if $(Platform) in android {
  CPPopt += -DWEBRTC_ANDROID=1 ;
}
else if $(Platform) in macOS tvOS {
  CPPopt += -DWEBRTC_MAC=1 ;
}
else if $(Platform) in iOS {
  CPPopt += -DWEBRTC_IOS=1 ;
}
else if $(Platform) in windows xboxOne scarlett {
  CPPopt += -DWEBRTC_WIN=1 ;
}

if ! $(Platform) in linux windows || $(Config) = rel {
  CPPopt += -DRTC_DISABLE_LOGGING=1 ;
}

if $(PlatformSpec) in clang gcc {
  CPPopt += -Wno-return-type -Wno-unused-parameter ;
}

if $(PlatformSpec) in vc17 vc16 {
  CPPopt +=  /wd4715 ;
}

if $(PlatformSpec) = clang {
  CPPopt += -Wno-nullability-completeness
            -Wno-thread-safety-reference-return # false-positive in metrics.cc
            ;
}

if $(PlatformArch) in x86 x86_64 {
  UseProgLibs += 3rdPartyLibs/webrtc-apm/avx2 ;

  Sources +=
      webrtc/common_audio/resampler/sinc_resampler_sse.cc
      webrtc/common_audio/third_party/ooura/fft_size_128/ooura_fft_sse2.cc
  ;
}

if $(PlatformArch) in arm64 arm64-v8a  {
  CPPopt += -DWEBRTC_HAS_NEON=1 -DWEBRTC_ARCH_ARM64=1 ;

  Sources +=
      webrtc/common_audio/resampler/sinc_resampler_neon.cc
      webrtc/common_audio/third_party/ooura/fft_size_128/ooura_fft_neon.cc
      webrtc/common_audio/signal_processing/min_max_operations_neon.c
      webrtc/common_audio/signal_processing/cross_correlation_neon.c
      webrtc/common_audio/signal_processing/downsample_fast_neon.c
      webrtc/modules/audio_processing/aecm/aecm_core_neon.cc
  ;
}

if $(Platform) in ps4 ps5 {
  Sources +=
    stubs/platform_thread_types_sony.cc
  ;
}
else {
  Sources +=
    webrtc/rtc_base/platform_thread_types.cc
  ;
}

