Root           ?= ../../.. ;
Location        = prog/3rdPartyLibs/arm_asr ;

TargetType      = lib ;
Target          = 3rdPartyLibs/arm_asr.lib ;

include $(Root)/prog/_jBuild/defaults.jam ;

Sources =
  src/shared/ffxm_assert.cpp
  src/shared/ffxm_object_management.cpp
  src/components/fsr2/ffxm_fsr2.cpp
  src/backends/shared/ffxm_shader_blobs.cpp
  src/backends/vk/ffxm_hash.cpp
  src/backends/vk/ffxm_vk.cpp
;

SHADERS_SRC = src/backends/shared/blob_accessors/ffxm_fsr2_shaderblobs.cpp ;
Sources += $(SHADERS_SRC) ;

PASS_SHADER_OUTPUT_PATH = $(Root)/$(Location)/src/backends/shared/blob_accessors/prebuilt_shaders/ ;

AddIncludes =
  $(Root)/$(Location)/include/
  $(Root)/$(Location)/include/host/
  $(Root)/$(Location)/src/backends/shared/
  $(Root)/$(Location)/src/backends/vk/
  $(Root)/$(Location)/include/gpu/
  $(Root)/$(Location)/src/components/
  $(Root)/$(Location)
  $(PASS_SHADER_OUTPUT_PATH)
;

CPPopt += -DFFXM_FSR ;
if $(CPPStd) < 20 { CPPopt += -std=c++20 ; }
CPPopt += -Wno-tautological-pointer-compare -Wno-pointer-bool-conversion ;

if $(Platform) in windows {
  AddIncludes += $(Root)/prog/3rdPartyLibs/vulkan/include ;
}

FSR2_BASE_ARGS = -reflection -deps=gcc -DFFXM_GPU=1 ;

FSR2_HLSL_BASE_ARGS =
  -E main -Wno-for-redefinition -Wno-ambig-lit-shift
  -DFFXM_HLSL=1 -DFFXM_HLSL_6_2=1
  -spirv -fspv-target-env=vulkan1.1spirv1.4
  -Wall -Wextra -Wno-conversion -Wundef
  -Wno-unused-const-variable -Wno-unused-parameter
  -Wno-unused-variable -Wno-unused-function
  -Wno-unknown-pragmas -Wuninitialized -HV 2021
;
FSR2_PERMUTATION_ARGS =
  -DFFXM_FSR2_OPTION_HDR_COLOR_INPUT={0,1}
  -DFFXM_FSR2_OPTION_LOW_RESOLUTION_MOTION_VECTORS={0,1}
  -DFFXM_FSR2_OPTION_JITTERED_MOTION_VECTORS={0,1}
  -DFFXM_FSR2_OPTION_INVERTED_DEPTH={0,1}
  -DFFXM_FSR2_OPTION_APPLY_SHARPENING={0,1}
  -DFFXM_FSR2_OPTION_SHADER_OPT_BALANCED={0,1}
  -DFFXM_FSR2_OPTION_SHADER_OPT_PERFORMANCE={0,1}
  -DFFXM_FSR2_OPTION_SHADER_OPT_ULTRA_PERFORMANCE={0,1}
;

FSR2_SC_ARGS = $(FSR2_BASE_ARGS) $(FSR2_HLSL_BASE_ARGS) $(FSR2_PERMUTATION_ARGS) ;

if ! [ GLOB $(_DEVTOOL)/FidelityFX_SC_ARM/ : * ] { exit FATAL\: \"$(_DEVTOOL)/FidelityFX_SC_ARM\" not found!  Please, update DEVTOOLS ; }
FFX_SC_EXECUTABLE = $(_DEVTOOL)/FidelityFX_SC_ARM/FidelityFX_SC.exe ;
PASS_SHADER_INPUT_PATH = $(Root)/$(Location)/src/backends/vk/shaders/fsr2/hlsl/ ;
PASS_SHADER_INCLUDES = -I $(Root)/$(Location)/include/gpu -I $(Root)/$(Location)/include/gpu/fsr2 ;

actions together quietly FidelityFX_CS
{
  # $(1) used only for dependencies, since output name is generated by FidelityFX shader compiler as (value passed to parameter -name=) + _permutations.h
  call $(FFX_SC_EXECUTABLE) $(FSR2_SC_ARGS) $(opt) -output=$(PASS_SHADER_OUTPUT_PATH) $(2)
}

# FidelityFX_CompileShader src : dst : params (including -name=) : target
rule FidelityFX_CompileShader
{
  local src = $(PASS_SHADER_INPUT_PATH)$(2).hlsl ;
  local dst = $(PASS_SHADER_OUTPUT_PATH)$(1)_permutations.h ;
  local target = $(4) ;
  opt on $(dst) = -name=$(1) $(3) ;
  Depends $(dst) : $(src) ;
  MakeDirectory $(dst) : $(dst:D) ;
  FidelityFX_CS  $(dst) : $(src) ;
  Includes $(target) : $(dst) ;
}

VS_SHADERS = ffxm_fsr2_vs ;
PS_SHADERS =
  ffxm_fsr2_accumulate_pass_fs
  ffxm_fsr2_autogen_reactive_pass_fs
  ffxm_fsr2_depth_clip_pass_fs
  ffxm_fsr2_rcas_pass_fs
  ffxm_fsr2_reconstruct_previous_depth_pass_fs
;
CS_SHADERS =
  ffxm_fsr2_compute_luminance_pyramid_pass
  ffxm_fsr2_lock_pass
;

for SHADER in $(VS_SHADERS) {
  FidelityFX_CompileShader $(SHADER)_16bit : $(SHADER) : -DFFXM_HALF=1 -enable-16bit-types -T vs_6_7 $(PASS_SHADER_INCLUDES) : $(Location)/$(SHADERS_SRC) ;
}
for SHADER in $(PS_SHADERS) {
  FidelityFX_CompileShader $(SHADER)_16bit : $(SHADER) : -DFFXM_HALF=1 -enable-16bit-types -T ps_6_7 $(PASS_SHADER_INCLUDES) : $(Location)/$(SHADERS_SRC) ;
}
for SHADER in $(CS_SHADERS) {
  FidelityFX_CompileShader $(SHADER)_16bit : $(SHADER) : -DFFXM_HALF=1 -enable-16bit-types -T cs_6_7 $(PASS_SHADER_INCLUDES) : $(Location)/$(SHADERS_SRC) ;
}

include $(Root)/prog/_jBuild/build.jam ;
