Root           ?= ../../.. ;
Location        = prog/3rdPartyLibs/netImgui ;

TargetType      = lib ;
Target          = 3rdPartyLibs/netImgui.lib ;

include $(Root)/prog/_jBuild/defaults.jam ;

AddIncludes =
  $(Root)/$(Location)
  $(Root)/$(Location)/nlohmann_json
  $(Root)/$(Location)/quicklz

  $(Root)/prog/3rdPartyLibs/imgui
  $(Root)/prog/3rdPartyLibs/stb
  $(Root)/prog/3rdPartyLibs/arc/zstd-$(ZstdVer)
;

Sources =
  source/NetImgui_Api.cpp
  source/NetImgui_Client.cpp
  source/NetImgui_CmdPackets_DrawFrame.cpp
  quicklz/quicklz.cpp
;
if $(Platform) in windows xboxOne scarlett {
  Sources += source/NetImgui_NetworkWin32.cpp ;
  CPPopt += -DNETIMGUI_WINSOCKET_ENABLED ;
}
if $(Platform) in linux macOS android ios {
  Sources += source/NetImgui_NetworkPosix.cpp ;
  CPPopt += -DNETIMGUI_POSIX_SOCKETS_ENABLED ;
}

UseProgLibs =
  3rdPartyLibs/imgui
  3rdPartyLibs/arc/zstd-$(ZstdVer)
;

include $(Root)/prog/_jBuild/build.jam ;
