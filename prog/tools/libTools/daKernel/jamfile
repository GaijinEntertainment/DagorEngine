Root    ?= ../../../.. ;
Location = prog/tools/libTools/daKernel ;

StrictCompile = yes ;
KernelLinkage = dynamic ;
ProjectAllowsOodle = yes ;
UseQuirrel = no ;
UseMemoryAllocator = RTL ;
LinuxUseGUI = no
include $(Root)/prog/tools/tools_setup.jam ;

TargetType    = dll ;
Target        = tools/libTools/daKernel ;
include $(Root)/prog/tools/tools_setup_outdir_bin.jam ;
if $(OutDirForDaKernel) { OutDir = $(OutDirForDaKernel) ; }

Sources =
  daKernel.cpp
  namedPtr.cpp
  gpFuncTable.cpp
;

AddIncludes =
  $(Root)/prog/tools/sharedInclude
  $(Root)/prog/engine/sharedInclude
;

CPPopt = -D__B_KERNEL_LIB ;

UseProgLibs =
  engine/osApiWrappers
  engine/kernel
  engine/memory
  engine/ioSys
  engine/baseUtil
  engine/perfMon
  engine/perfMon/daProfiler
;
Dependencies = $(Root)/prog/tools/libTools/daKernel/eastl-local.jam ;

if $(Platform) in windows {
  UseProgLibs +=
    engine/osApiWrappers/messageBox
  ;
  AddLibs =
    dbghelp.lib
    user32.lib
    #shell32.lib gdi32.lib comctl32.lib
  ;
}

if $(Platform) in linux {
  # separate fpic code from everything else
  UseProgLibs +=
    engine/osApiWrappers/messageBox/stub
    engine/workCycle/stub
  ;
  AddLibs = -ldl -lpthread -lrt -lm -lstdc++ --no-undefined ;

  # set the default visibility of all symbols to be hidden to prevent them from being visible across library boundaries
  CPPopt += -fvisibility=hidden ;
}

include $(Root)/prog/_jBuild/build.jam ;
