Root    ?= ../../.. ;
Location = prog/tools/shaderInfo ;
include $(Root)/prog/tools/tools_setup.jam ;
ConsoleExe = yes ;

TargetType  = exe ;
Target = tools/util/shaderInfo ;
include $(Root)/prog/tools/tools_setup_outdir_util.jam ;

CPPopt += -DSET_DEFAULT_MAX_SHVARS=8192 ;

AddIncludes =
  $(Root)/prog/engine/shaders
  $(Root)/prog/engine/sharedInclude
  $(Root)/prog/tools/ShaderCompiler2/shaderBlobDisassembler/include
;

Sources =
  shaderInfo.cpp
  main.cpp
;

UseProgLibs =
  engine/osApiWrappers
  engine/kernel
  engine/memory
  engine/ioSys
  engine/startup
  engine/baseUtil
  engine/math
  engine/lib3d
  engine/drv/drv3d_null
  3rdPartyLibs/eastl
  3rdPartyLibs/hash/BLAKE3
  engine/shaders
  engine/perfMon/daProfilerStub
  tools/ShaderCompiler2/shaderBlobDisassembler
;

if $(Platform) = linux {
  UseProgLibs += engine/osApiWrappers/messageBox/stub ;
}

if $(OS) = NT {
  AddLibs += D3dcompiler.lib ;
}

include $(Root)/prog/_jBuild/build.jam ;
