Root    ?= ../../.. ;

Location = prog/tools/relay ;
PlatformArch_windows ?= x86_64 ;
PlatformSpec_windows ?= clang ;
UseMemoryAllocator = RTL ;

include $(Root)/prog/_jBuild/defaults.jam ;

ConsoleExe = yes ;
TargetType = exe ;
Target     = relay ;
echo $(Root) ;
if $(ProjectPath) {
  echo $(ProjectPath) ;
  GameDir = $(Root)/$(ProjectPath)/game ;
  echo $(GameDir) ;
} else {
  echo ProjectPath not set, building to _Output ;
}

if $(UseLegacyOutDirPath) = yes {
  OutDir = $(GameDir)/$(LegacyPlatformSuffix) ;
}
else {
  OutDir = $(GameDir)/$(Platform)-$(PlatformArch) ;
}


Sources =
  relay.cpp
;

AddIncludes =
  $(Root)/prog/engine/dagorInclude
  $(Root)/prog/gameLibs/publicInclude
  $(Root)/prog/3rdPartyLibs/enet/include
;

UseProgLibs =
  engine/osApiWrappers
  engine/kernel
  engine/memory
  engine/ioSys
  engine/startup
  engine/baseUtil
  engine/math
  engine/perfMon/daProfilerStub
  engine/daNet
;

include $(Root)/prog/_jBuild/build.jam ;
