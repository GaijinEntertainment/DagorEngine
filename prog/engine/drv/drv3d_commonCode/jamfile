Root    ?= ../../../.. ;
Location = prog/engine/drv/drv3d_commonCode ;

include $(Root)/prog/_jBuild/defaults.jam ;

TargetType  = lib ;
Target      = engine/drv/drv3d_commonCode.lib ;
if $(UseD3DMulti) = yes && $(UseD3DMultiList) = stub { Target = $(Target:S=-s.lib) ; }

Sources =
  drvDecl.cpp
  gpuMem.cpp
  gpuVendor.cpp
  gpuConfig.cpp
  display.cpp
  d3dToTexFmt.cpp
  basetexture.cpp
  drv_utils.cpp
  drv_resourceChecker.cpp
  dxgi_utils.cpp
  stereoHelper.cpp
  hangHandler.cpp
  ICrashFallback.cpp
  drv_returnAddrStore.cpp
  resUpdateBufferGeneric.cpp
  resourceActivationGeneric.cpp
  destroyEvent.cpp
  gpuLatency.cpp
;

if $(Platform) in windows {
  Sources +=
    winapi_helpers.cpp
  ;
}

if $(Platform) = macOS {
  Sources +=
    gpuMemM.mm
    macosx/macWnd.mm
  ;
}

if $(Platform) in macOS iOS tvOS {
  Sources +=
    displayM.mm
  ;
}

if $(Platform) in windows && $(PlatformArch) in x86 x86_64 {
  local NvApiDir = $(_DEVTOOL)/nvapi-$(NvApiVer) ;
  if ! [ GLOB $(NvApiDir) : * ] { exit FATAL\: \"$(NvApiDir)\" not found!  Please, update DEVTOOLS ; }

  AddIncludes += $(NvApiDir) ;
  CPPopt += -DHAS_NVAPI ;
  Sources += nvLowLatency.cpp ;
  switch $(PlatformArch) {
    case x86 :    AddLibs += $(NvApiDir)/x86/nvapi.lib ;
    case x86_64 : AddLibs += $(NvApiDir)/amd64/nvapi64.lib ;
  }
} else {
  Sources += nvLowLatencyStub.cpp ;
}

if $(Platform) in windows &&
  $(PlatformArch) in x86_64 &&
  $(UseD3DMultiList) != stub {
  AddIncludes += $(Root)/prog/3rdPartyLibs/AntiLag2 ;
  Sources += amdLowLatency.cpp ;
} else {
  Sources += amdLowLatencyStub.cpp ;
}

if $(Platform) in windows &&
   $(PlatformArch) in x86 x86_64 &&
   [ GLOB $(Root)/prog/3rdPartyLibs/streamline : * ] {
  AddIncludes +=
    $(Root)/prog/3rdPartyLibs/streamline/include
    $(Root)/prog/3rdPartyLibs/vulkan/include
  ;
  CPPopt += -DHAS_STREAMLINE ;
  Sources += streamline_adapter.cpp ;
} else {
  Sources += streamline_adapter_stub.cpp ;
}

if $(Platform) in windows &&
   $(PlatformArch) in x86 x86_64 &&
   [ GLOB $(Root)/prog/3rdPartyLibs/adl_sdk : * ] {
  AddIncludes += $(Root)/prog/3rdPartyLibs/adl_sdk/include ;
  CPPopt += -DHAS_ADL ;
}

if $(Platform) in windows &&
   $(PlatformArch) in x86 x86_64 &&
   [ GLOB $(Root)/prog/3rdPartyLibs/AmdDxExt : * ] {
  AddIncludes += $(Root)/prog/3rdPartyLibs/AmdDxExt ;
  CPPopt += -DHAS_AMD_DX_EXT ;
}

if $(Platform) in windows xboxOne scarlett ps5 linux &&
   $(PlatformArch) in x86_64 arm64 &&
   $(UseD3DMultiList) != stub && $(Dedicated) != yes && $(UseStubDriver) != yes {
  Sources += amdFsr.cpp ;

  if $(Platform)-$(PlatformArch) in windows-x86_64 && vulkan in $(UseD3DMultiList) {
    opt on amdFsr.cpp += -DAMDFSR_HAS_VULKAN ;
  } else if $(Platform)-$(PlatformArch) in linux-x86_64 {
    opt on amdFsr.cpp += -DAMDFSR_HAS_VULKAN ;
  } else {
    Target = $(Target:S=~nSpirV.lib) ;
  }

  if $(Platform) in xboxOne scarlett || ( $(Platform)-$(PlatformArch) = windows-x86_64 && DX12 in $(UseD3DMultiList) ) {
    opt on amdFsr.cpp += -DAMDFSR_HAS_DX12 ;
  } else {
    Target = $(Target:S=~nDX12.lib) ;
  }
} else {
  Sources += amdFsr_stub.cpp ;
}

AddIncludes +=
  $(Root)/prog/engine/sharedInclude
  $(Root)/prog/engine/drv/drv3d_commonCode
;

if $(Platform) in ps4 ps5 {
  AddIncludes += $(Root)/prog/engine/drv/drv3d_commonCode/sony ;
  Sources +=
    sony/base_texture.cpp
    sony/base_buffer.cpp
    sony/base_shader_state.cpp
    sony/d3d_frontend_common.cpp
    sony/bindless.cpp
    sony/command_queue_dump.cpp
    sony/info_panel_common.cpp
    sony/driver_common.cpp
    sony/sampler.cpp
    sony/res_heaps.cpp
    sony/memory_block_ptr.cpp
    sony/crash_dump.cpp
  ;
}

include $(Root)/prog/_jBuild/build.jam ;
