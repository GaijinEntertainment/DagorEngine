Root    ?= ../../../.. ;
Location = prog/engine/drv/drv3d_DX11 ;

include $(Root)/prog/_jBuild/defaults.jam ;

TargetType  = lib ;
Target      = engine/drv/drv3d_DX11.lib ;

Sources =
  init.cpp
  drvmain.cpp
  states.cpp
  rtarget.cpp
  texture.cpp
  shaders.cpp
  buffers.cpp
  sampler.cpp
  genericBuffer.cpp
  init_d3di.cpp
  basetex.cpp
  immediateConst.cpp
  helpers.cpp
  memory_metrics.cpp
  clear.cpp
;


AddIncludes =
  $(Root)/prog/engine/sharedInclude
  $(Root)/prog/engine/drv/drv3d_commonCode
;

AddLibs += Version.lib ;

CPPopt = -DINSIDE_DRIVER -FId3d_config.h ;

if $(Platform) in windows && $(PlatformArch) in x86 x86_64 {
  AddIncludes += $(_DEVTOOL)/nvapi-$(NvApiVer) ;
  CPPopt += -DHAS_NVAPI ;
}

if $(Platform) in windows &&
   $(PlatformArch) in x86 x86_64 &&
   [ GLOB $(Root)/prog/3rdPartyLibs/adl_sdk : * ] {
  AddIncludes += $(Root)/prog/3rdPartyLibs/adl_sdk/include ;
  CPPopt += -DHAS_ADL ;
}

if $(Platform) in windows &&
   $(PlatformArch) in x86 x86_64 &&
   [ GLOB $(Root)/prog/3rdPartyLibs/AmdDxExt : * ] {
  AddIncludes += $(Root)/prog/3rdPartyLibs/AmdDxExt ;
  CPPopt += -DHAS_AMD_DX_EXT ;
}

if $(Platform) in windows &&
   $(PlatformArch) in x86 x86_64 &&
   [ GLOB $(Root)/prog/3rdPartyLibs/aftermath : * ] {
  AddIncludes += $(Root)/prog/3rdPartyLibs/aftermath/2025.5.0.251114/include ;
  CPPopt += -DHAS_GF_AFTERMATH ;
}

if $(Platform) in windows && $(PlatformArch) in x86 x86_64 {
  AddIncludes += $(Root)/prog/3rdPartyLibs/streamline/include ;
}

UseProgLibs = engine/drv/drv3d_commonCode ;

include $(Root)/prog/_jBuild/build.jam ;
