Root    ?= ../../../.. ;
Location = prog/engine/drv/hid_mouse ;
LinuxUseGUI ?= yes ;

include $(Root)/prog/_jBuild/defaults.jam ;

TargetType  = lib ;
Target      = engine/drv/hid_mouse.lib ;
if $(Platform) = linux && $(LinuxUseGUI) != yes { Exit $(Target) requires LinuxUseGUI\=yes under $(Platform) ; }

Sources =
  ms_device_common.cpp

  ms_classdrv_win.cpp
  ms_device_win.cpp
;

AddIncludes = $(Root)/prog/engine/sharedInclude ;

if $(Platform) = macOS {
  Sources +=
    macosx_ms_api.mm
  ;
}

if $(Platform) in linux {
  Sources +=
    linux_ms_api.cpp
  ;
  UseProgLibs += engine/osApiWrappers/linuxGUI ;
}

if $(Platform) = windows {
  Sources +=
    windows_ms_api.cpp
  ;
}

include $(Root)/prog/_jBuild/build.jam ;
