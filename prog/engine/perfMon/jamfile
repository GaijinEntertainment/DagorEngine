Root    ?= ../../.. ;
Location = prog/engine/perfMon ;
StrictCompile = yes ;

include $(Root)/prog/_jBuild/defaults.jam ;

TargetType  = lib ;
Target      = engine/perfMon.lib ;

AddIncludes =
  $(Root)/prog/engine/sharedInclude
  $(Root)/prog/engine/perfMon
;

Sources =
  profilerModes.cpp
  profilerSettings.cpp
  visClipMesh.cpp
  stat3d.cpp
  tdrProfile.cpp
  statStd.cpp
  perfMonStat.cpp
  sleepPrecise.cpp
  memoryReport.cpp
  memoryReportVramQuery.cpp
  memoryReportLog.cpp
;

if $(Config) != rel {
  Sources += alternateProfiler.cpp ;

  if $(Platform) = windows && $(PlatformArch) in arm64 x86_64 && [ GLOB $(Root)/prog/3rdPartyLibs/winpixeventruntime : * ] {
    AddIncludes += $(Root)/prog/3rdPartyLibs/winpixeventruntime/Include/WinPixEventRuntime ;
    if $(PlatformArch) = arm64 {
      AddLibs += $(Root)/prog/3rdPartyLibs/winpixeventruntime/bin/ARM64/WinPixEventRuntime.lib ;
    } else if $(PlatformArch) = x86_64 {
      AddLibs += $(Root)/prog/3rdPartyLibs/winpixeventruntime/bin/x64/WinPixEventRuntime.lib ;
    }
    AddLibs += delayimp.lib -delayload:WinPixEventRuntime.dll ;
    Sources += pix.cpp ;
    opt on pix.cpp += -DUSE_PIX -DPIX_USE_GPU_MARKERS_V2 ;
  } else if $(Platform) in xboxOne scarlett {
    AddLibs += PIXEvt.lib ;
    Sources += pix.cpp ;
    opt on pix.cpp += -DUSE_PIX ;
  } else {
    Sources += stub/pix.cpp ;
  }
} else {
  Sources += stub/pix.cpp ;
}

UseGpu ?= yes ;

if $(UseGpu) = yes {
  Sources += gpuProfiler.cpp ;
}
else {
  Target = $(Target:S=~noGPU.lib) ;
  UseProgLibs += engine/perfMon/gpuProfilerStub ;
}

if $(Platform)-$(PlatformArch) = windows-x86_64 {
  CacheSim ?= no ;
} else {
  CacheSim = no ; # not supported
}

if $(CacheSim) = yes {
  Target = $(Target:S=~cachesim.lib) ;
  Sources += cachesim.cpp ;
  UseProgLibs += 3rdPartyLibs/cachesim ;
}
else {
  Sources += stub/cachesim.cpp ;
}

if $(KernelLinkage) != dynamic { UseProgLibs += engine/perfMon/daProfiler ; }

include $(Root)/prog/_jBuild/build.jam ;
